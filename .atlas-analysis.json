  "keyFeatures": [
    "TypeScript SDK with createZilMate() factory for Next.js and server environments",
    "CLI binary (zilmate) with interactive chat, voice, and one-shot task execution",
    "Hierarchical Manager Agent (CEO) orchestrating 30+ specialist swarm agents",
    "Decentralized peer-to-peer Joint War Rooms for cross-department collaboration",
    "Semantic Corporate Wiki backed by Upstash Vector or SuperMemory",
    "Long-term memory with remember/recall API",
    "Background job scheduling via cron, QStash, and Cloudflare tunnel webhooks",
    "Real-time voice control powered by Deepgram (STT + TTS)",
    "Semantic Approvals Firewall for human-in-the-loop safety on destructive actions",
    "Composio integration for 100+ external app connectors",
    "Cloud storage tools: AWS S3, Google Cloud Storage, Vercel Blob",
    "Multimedia tools: FFmpeg processing and Deepgram transcription",
    "Session continuity with handoff summaries across runs",
    "Model-per-agent selection persisted to workspace config"
  ],
  "publicApiSurface": [
    "createZilMate({ sessionId?, onProgress?, confirm? })",
    "zilmate.manager({ message })",
    "zilmate.chat({ message })",
    "zilmate.coding({ prompt })",
    "zilmate.research({ query })",
