    "zilmate.situation({ sessionId })",
    "zilmate.handoff({ sessionId })",
    "zilmate.remember({ text, tags? })",
    "zilmate.recall({ query?, limit? })",
    "zilmate.listMemories()",
    "zilmate.forget(id)",
    "zilmate.clearMemories()",
    "zilmate.createJob({ task, schedule?, maxAttempts? })",
    "zilmate.listJobs(options?)",
    "zilmate.getJob(id)",
    "zilmate.getJobLogs(id)",
    "zilmate.runJob(id)",
    "zilmate.runDueJobs()",
    "zilmate.cancelJob(id)",
    "zilmate.handleJobWebhook(body, secret)",
    "zilmate.startVoiceSession({ onProgress? })",
    "zilmate.getVoiceConfig()",
    "applyStoredModelSelections()",
    "saveModelSelection(agentKey, modelId)",
    "buildSituationBrief(sessionId)",
    "loadSessionHandoff(sessionId)",
